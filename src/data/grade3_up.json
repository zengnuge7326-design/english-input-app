[
  { "id": 1,  "zh": "你好！我是迈克·布莱克。", "en": "Hello! I'm Mike Black." },
  { "id": 2,  "zh": "嗨！我叫吴斌斌。", "en": "Hi! My name is Wu Binbin." },
  { "id": 3,  "zh": "见到你很高兴。", "en": "Nice to meet you." },
  { "id": 4,  "zh": "见到你我也很高兴。", "en": "Nice to meet you too." },
  { "id": 5,  "zh": "噢，不！", "en": "Oh no!" },
  { "id": 6,  "zh": "没关系，陈杰。", "en": "It's OK, Chen Jie." },
  { "id": 7,  "zh": "嘿，萨拉！我们可以分享。", "en": "Hey, Sarah! We can share." },
  { "id": 8,  "zh": "谢谢，萨拉。", "en": "Thanks, Sarah." },
  { "id": 9,  "zh": "谢谢你，陈杰。", "en": "Thank you, Chen Jie." },
  { "id": 10, "zh": "我倾听。", "en": "I listen with care." },
  { "id": 11, "zh": "我对我的朋友们很好。", "en": "I am nice to my friends." },
  { "id": 12, "zh": "这是我的奶奶。", "en": "This is my grandma." },
  { "id": 13, "zh": "看！这是我的家庭。", "en": "Look! This is my family." },
  { "id": 14, "zh": "那是你弟弟吗？", "en": "Is that your brother?" },
  { "id": 15, "zh": "对，是的。", "en": "Yes, it is." },
  { "id": 16, "zh": "家庭之间是不同的，但家人之爱是相同的。", "en": "Families are different, but family love is the same." },
  { "id": 17, "zh": "早上好，迈克！", "en": "Good morning, Mike!" },
  { "id": 18, "zh": "早上好！进来吧。", "en": "Good morning! Come in." },
  { "id": 19, "zh": "你有宠物吗？", "en": "Do you have a pet?" },
  { "id": 20, "zh": "不，我没有。", "en": "No, I don't." },
  { "id": 21, "zh": "是的，我有。我有一只猫。", "en": "Yes, I do. I have a cat." },
  { "id": 22, "zh": "我们一起去动物园吧！", "en": "Let's go to the zoo!" },
  { "id": 23, "zh": "太好了！", "en": "Great!" },
  { "id": 24, "zh": "这是什么？", "en": "What's this?" },
  { "id": 25, "zh": "是只狐狸。", "en": "It's a fox." },
  { "id": 26, "zh": "怀特老师，那是什么？", "en": "Miss White, what's that?" },
  { "id": 27, "zh": "是只小熊猫。", "en": "It's a red panda." },
  { "id": 28, "zh": "迈克，你喜欢苹果吗？", "en": "Mike, do you like apples?" },
  { "id": 29, "zh": "是的，我喜欢。你呢？", "en": "Yes, I do. And you?" },
  { "id": 30, "zh": "不，我不喜欢。", "en": "No, I don't." },
  { "id": 31, "zh": "你们喜欢农场吗？", "en": "Do you like the farm?" },
  { "id": 32, "zh": "我喜欢新鲜的空气。", "en": "I like fresh air." },
  { "id": 33, "zh": "我们可以种些新树。", "en": "We can plant new trees." },
  { "id": 34, "zh": "它们帮助植物生长。", "en": "They help plants grow." },
  { "id": 35, "zh": "植物可以给予我们很多东西。", "en": "Plants can give us many things." },
  { "id": 36, "zh": "它是什么颜色？", "en": "What colour is it?" },
  { "id": 37, "zh": "它是橙红色。", "en": "It's orange." },
  { "id": 38, "zh": "红色加蓝色是紫色。", "en": "Red and blue make purple." },
  { "id": 39, "zh": "你喜欢什么颜色？", "en": "What colours do you like?" },
  { "id": 40, "zh": "我喜欢红色 and 粉色。", "en": "I like red and pink." },
  { "id": 41, "zh": "我们一起画一些紫色 and 棕色的鸟吧。", "en": "Let's draw some purple and brown birds." },
  { "id": 42, "zh": "再次利用！", "en": "Use again!" },
  { "id": 43, "zh": "小心！", "en": "Be careful!" },
  { "id": 44, "zh": "你几岁了？", "en": "How old are you?" },
  { "id": 45, "zh": "我五岁了。", "en": "I'm five years old." },
  { "id": 46, "zh": "我也是。", "en": "Me too." },
  { "id": 47, "zh": "几个苹果？", "en": "How many apples?" },
  { "id": 48, "zh": "两个。", "en": "Two." },
  { "id": 49, "zh": "好极了！我们一起去商店吧！", "en": "Great! Let's go to the shop!" },
  { "id": 50, "zh": "（共）十元，谢谢。", "en": "That's ten yuan, please." },
  { "id": 51, "zh": "给您。", "en": "Here you are." },
  { "id": 52, "zh": "七点了。快点！", "en": "It's seven o'clock. Hurry!" },
  { "id": 53, "zh": "生日快乐！", "en": "Happy birthday!" },
  { "id": 54, "zh": "噢，再切一块给小狗。", "en": "Oh, one more cut for the dog." }
]
