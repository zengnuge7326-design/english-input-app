[
  { "id": 1,  "zh": "你叫 what's your name? 吗？", "en": "What's your name?" },
  { "id": 2,  "zh": "我叫埃米·格林。", "en": "My name's Amy Green." },
  { "id": 3,  "zh": "你是哪里人？", "en": "Where are you from?" },
  { "id": 4,  "zh": "我是英国人。", "en": "I'm from the UK." },
  { "id": 5,  "zh": "我来帮忙。", "en": "Let me help." },
  { "id": 6,  "zh": "您先请！", "en": "After you!" },
  { "id": 7,  "zh": "别客气。", "en": "You're welcome." },
  { "id": 8,  "zh": "那个女孩是谁？", "en": "Who's that girl?" },
  { "id": 9,  "zh": "是我们的新邻居埃米。", "en": "That's our new neighbour, Amy." },
  { "id": 10, "zh": "你经常对妈妈那么说吗？", "en": "Do you often say that to your mum?" },
  { "id": 11, "zh": "是的。", "en": "Yes, I do." },
  { "id": 12, "zh": "我经常给她做礼物。", "en": "I often make her gifts." },
  { "id": 13, "zh": "我们用很多种方式表达自己。", "en": "We express ourselves in many ways." },
  { "id": 14, "zh": "它有长长的身体和短短的腿。", "en": "It has a long body and short legs." },
  { "id": 15, "zh": "狗是友善的。", "en": "Dogs are friendly." },
  { "id": 16, "zh": "劳驾。", "en": "Excuse me." },
  { "id": 17, "zh": "我能用一下你的橡皮吗？", "en": "Can I use your eraser, please?" },
  { "id": 18, "zh": "当然。给你。", "en": "Sure. Here you are." },
  { "id": 19, "zh": "没问题。", "en": "No problem." },
  { "id": 20, "zh": "这些是什么？", "en": "What are these?" },
  { "id": 21, "zh": "是葡萄。", "en": "They're grapes." },
  { "id": 22, "zh": "这个呢？", "en": "What about this?" },
  { "id": 23, "zh": "我想吃点儿面包和鸡蛋。", "en": "I'd like some bread and eggs, please." },
  { "id": 24, "zh": "也喝点儿牛奶吧。", "en": "Have some milk too." },
  { "id": 25, "zh": "要吃点儿米饭和肉吗？", "en": "Would you like some rice and meat?" },
  { "id": 26, "zh": "好的，谢谢。", "en": "Yes, please." },
  { "id": 27, "zh": "每天吃一些吧！", "en": "Eat some every day!" },
  { "id": 28, "zh": "你有旧东西吗？", "en": "Do you have old things?" },
  { "id": 29, "zh": "是的。我有些旧书。", "en": "Yes, I do. I have some old books." },
  { "id": 30, "zh": "这只船很酷。", "en": "This boat is cool." },
  { "id": 31, "zh": "你可以留着它。", "en": "You can keep it." },
  { "id": 32, "zh": "妈妈，我的动物书在哪儿？", "en": "Mum, where is my animal book?" },
  { "id": 33, "zh": "在架子上吗？", "en": "Is it on the shelf?" },
  { "id": 34, "zh": "不，不在。", "en": "No, it isn't." },
  { "id": 35, "zh": "它在盒子里。", "en": "It's in the box." },
  { "id": 36, "zh": "我们有多少本书？", "en": "How many books do we have?" },
  { "id": 37, "zh": "我们有十五本书。", "en": "We have fifteen books." },
  { "id": 38, "zh": "我们需要多少个箱子？", "en": "How many boxes do we need?" },
  { "id": 39, "zh": "我们需要三个箱子。", "en": "We need three boxes." },
  { "id": 40, "zh": "这个包多少钱？", "en": "How much is this bag?" },
  { "id": 41, "zh": "二十元。", "en": "It's twenty yuan." },
  { "id": 42, "zh": "六元，或者十七元三本。", "en": "Six yuan, or three for seventeen yuan." },
  { "id": 43, "zh": "十六元三本行吗？", "en": "How about three for sixteen yuan?" }
]
