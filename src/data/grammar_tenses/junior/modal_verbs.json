[
  { "id": 1,  "zh": "我会游泳。", "en": "I can swim." },
  { "id": 2,  "zh": "她会弹钢琴。", "en": "She can play the piano." },
  { "id": 3,  "zh": "他不会开车。", "en": "He cannot drive." },
  { "id": 4,  "zh": "你会说法语吗？", "en": "Can you speak French?" },
  { "id": 5,  "zh": "我可以借你的笔吗？", "en": "Can I borrow your pen?" },
  { "id": 6,  "zh": "当然可以。", "en": "Of course you can." },
  { "id": 7,  "zh": "他小时候能跑得很快。", "en": "He could run very fast when he was young." },
  { "id": 8,  "zh": "你能帮我一下吗？", "en": "Could you help me?" },
  { "id": 9,  "zh": "你可以进来了。", "en": "You may come in." },
  { "id": 10, "zh": "我可以用你的电话吗？", "en": "May I use your phone?" },
  { "id": 11, "zh": "他可能今天不来了。", "en": "He may not come today." },
  { "id": 12, "zh": "她可能在图书馆。", "en": "She might be in the library." },
  { "id": 13, "zh": "你必须按时完成作业。", "en": "You must finish your homework on time." },
  { "id": 14, "zh": "这里不能吸烟。", "en": "You must not smoke here." },
  { "id": 15, "zh": "他一定是累了。", "en": "He must be tired." },
  { "id": 16, "zh": "我今天必须去医院。", "en": "I have to go to the hospital today." },
  { "id": 17, "zh": "她不必早起。", "en": "She does not have to get up early." },
  { "id": 18, "zh": "你应该多锻炼。", "en": "You should exercise more." },
  { "id": 19, "zh": "他不应该说谎。", "en": "He should not tell lies." },
  { "id": 20, "zh": "你应该向她道歉。", "en": "You ought to apologize to her." },
  { "id": 21, "zh": "你最好早点出发。", "en": "You had better leave early." },
  { "id": 22, "zh": "你最好不要迟到。", "en": "You had better not be late." },
  { "id": 23, "zh": "他一定没有听到消息。", "en": "He can't have heard the news." },
  { "id": 24, "zh": "她一定已经离开了。", "en": "She must have left." },
  { "id": 25, "zh": "他本应该早点来的。", "en": "He should have come earlier." },
  { "id": 26, "zh": "我本可以帮助你的。", "en": "I could have helped you." },
  { "id": 27, "zh": "你不必那么担心。", "en": "You need not worry so much." },
  { "id": 28, "zh": "他敢一个人去吗？", "en": "Dare he go alone?" },
  { "id": 29, "zh": "你愿意帮我吗？", "en": "Would you like to help me?" },
  { "id": 30, "zh": "我宁愿待在家里。", "en": "I would rather stay at home." }
]
