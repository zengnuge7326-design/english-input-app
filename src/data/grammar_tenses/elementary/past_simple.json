[
  { "id": 1,  "zh": "昨天天气很好。", "en": "The weather was nice yesterday." },
  { "id": 2,  "zh": "我昨天很累。", "en": "I was tired yesterday." },
  { "id": 3,  "zh": "他们上周在北京。", "en": "They were in Beijing last week." },
  { "id": 4,  "zh": "她小时候很害羞。", "en": "She was shy when she was young." },
  { "id": 5,  "zh": "这部电影很有趣。", "en": "The movie was interesting." },
  { "id": 6,  "zh": "我们昨天不在学校。", "en": "We were not at school yesterday." },
  { "id": 7,  "zh": "他昨天不舒服。", "en": "He was not well yesterday." },
  { "id": 8,  "zh": "你昨天在哪里？", "en": "Where were you yesterday?" },
  { "id": 9,  "zh": "他们上周快乐吗？", "en": "Were they happy last week?" },
  { "id": 10, "zh": "是的，他们很快乐。", "en": "Yes, they were." },
  { "id": 11, "zh": "那次考试难吗？", "en": "Was the exam difficult?" },
  { "id": 12, "zh": "不，不难。", "en": "No, it was not." },
  { "id": 13, "zh": "那家餐厅的食物好吃吗？", "en": "Was the food good at that restaurant?" },
  { "id": 14, "zh": "他们昨晚在派对上吗？", "en": "Were they at the party last night?" },
  { "id": 15, "zh": "你小时候是个好学生吗？", "en": "Were you a good student when you were young?" },
  { "id": 16, "zh": "我昨天打扫了房间。", "en": "I cleaned my room yesterday." },
  { "id": 17, "zh": "她昨晚看了一部电影。", "en": "She watched a movie last night." },
  { "id": 18, "zh": "他们上周末去了公园。", "en": "They visited the park last weekend." },
  { "id": 19, "zh": "我妈妈做了一顿美味的晚餐。", "en": "My mother cooked a delicious dinner." },
  { "id": 20, "zh": "他昨天帮助了我。", "en": "He helped me yesterday." },
  { "id": 21, "zh": "她昨天练习了钢琴。", "en": "She practiced the piano yesterday." },
  { "id": 22, "zh": "他步行去了学校。", "en": "He walked to school." },
  { "id": 23, "zh": "他没有完成作业。", "en": "He did not finish his homework." },
  { "id": 24, "zh": "我没有看那场比赛。", "en": "I did not watch the game." },
  { "id": 25, "zh": "你昨天做了什么？", "en": "What did you do yesterday?" },
  { "id": 26, "zh": "她昨晚几点睡觉的？", "en": "What time did she go to bed last night?" },
  { "id": 27, "zh": "你喜欢那部电影吗？", "en": "Did you like the movie?" },
  { "id": 28, "zh": "我昨天去了图书馆。", "en": "I went to the library yesterday." },
  { "id": 29, "zh": "她昨晚吃了披萨。", "en": "She had pizza last night." },
  { "id": 30, "zh": "他们来我家玩了。", "en": "They came to my house to play." },
  { "id": 31, "zh": "我在公园看见了一只兔子。", "en": "I saw a rabbit in the park." },
  { "id": 32, "zh": "他得了满分。", "en": "He got full marks." },
  { "id": 33, "zh": "我们做了一个大蛋糕。", "en": "We made a big cake." },
  { "id": 34, "zh": "她给我写了一封信。", "en": "She wrote me a letter." },
  { "id": 35, "zh": "他跑得很快。", "en": "He ran very fast." },
  { "id": 36, "zh": "我们唱了很多歌。", "en": "We sang many songs." },
  { "id": 37, "zh": "她买了一件新裙子。", "en": "She bought a new dress." },
  { "id": 38, "zh": "他告诉我一个秘密。", "en": "He told me a secret." },
  { "id": 39, "zh": "我找到了我的钥匙。", "en": "I found my keys." },
  { "id": 40, "zh": "他们赢了比赛。", "en": "They won the game." },
  { "id": 41, "zh": "上个周末，我和家人去了动物园。", "en": "Last weekend, I went to the zoo with my family." },
  { "id": 42, "zh": "我们早上八点出发。", "en": "We left at eight o'clock in the morning." },
  { "id": 43, "zh": "我们看见了很多动物。", "en": "We saw many animals." },
  { "id": 44, "zh": "我们在那里吃了午饭。", "en": "We had lunch there." },
  { "id": 45, "zh": "下午，我们拍了很多照片。", "en": "In the afternoon, we took many photos." },
  { "id": 46, "zh": "孩子们玩得非常开心。", "en": "The children had a great time." },
  { "id": 47, "zh": "我买了一个纪念品。", "en": "I bought a souvenir." },
  { "id": 48, "zh": "我们下午五点回家了。", "en": "We went home at five in the afternoon." },
  { "id": 49, "zh": "我很累，但很快乐。", "en": "I was tired but happy." },
  { "id": 50, "zh": "那天晚上我很早就睡着了。", "en": "I fell asleep early that night." }
]
