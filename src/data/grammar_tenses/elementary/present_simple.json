[
  { "id": 1,  "zh": "我是一名学生。", "en": "I am a student." },
  { "id": 2,  "zh": "她是我的老师。", "en": "She is my teacher." },
  { "id": 3,  "zh": "他们是好朋友。", "en": "They are good friends." },
  { "id": 4,  "zh": "这只猫是白色的。", "en": "The cat is white." },
  { "id": 5,  "zh": "我很高兴。", "en": "I am happy." },
  { "id": 6,  "zh": "天气很晴朗。", "en": "The weather is sunny." },
  { "id": 7,  "zh": "这些苹果是红色的。", "en": "These apples are red." },
  { "id": 8,  "zh": "我不是一名医生。", "en": "I am not a doctor." },
  { "id": 9,  "zh": "他不在家。", "en": "He is not at home." },
  { "id": 10, "zh": "你是学生吗？", "en": "Are you a student?" },
  { "id": 11, "zh": "她是你的妈妈吗？", "en": "Is she your mother?" },
  { "id": 12, "zh": "他们是双胞胎吗？", "en": "Are they twins?" },
  { "id": 13, "zh": "这本书是你的吗？", "en": "Is this book yours?" },
  { "id": 14, "zh": "不，它不是我的。", "en": "No, it is not mine." },
  { "id": 15, "zh": "是的，我是。", "en": "Yes, I am." },
  { "id": 16, "zh": "我每天早上刷牙。", "en": "I brush my teeth every morning." },
  { "id": 17, "zh": "她每天喝牛奶。", "en": "She drinks milk every day." },
  { "id": 18, "zh": "他喜欢踢足球。", "en": "He likes playing football." },
  { "id": 19, "zh": "我们每天上学。", "en": "We go to school every day." },
  { "id": 20, "zh": "他每晚看书。", "en": "He reads books every night." },
  { "id": 21, "zh": "猫喜欢睡觉。", "en": "Cats like sleeping." },
  { "id": 22, "zh": "她每周日去教堂。", "en": "She goes to church every Sunday." },
  { "id": 23, "zh": "我的爸爸开车上班。", "en": "My father drives to work." },
  { "id": 24, "zh": "鸟儿每天早上唱歌。", "en": "Birds sing every morning." },
  { "id": 25, "zh": "他不喜欢吃蔬菜。", "en": "He does not like vegetables." },
  { "id": 26, "zh": "我不看电视。", "en": "I do not watch TV." },
  { "id": 27, "zh": "她住在北京吗？", "en": "Does she live in Beijing?" },
  { "id": 28, "zh": "你喜欢音乐吗？", "en": "Do you like music?" },
  { "id": 29, "zh": "他每天几点起床？", "en": "What time does he get up every day?" },
  { "id": 30, "zh": "他们在哪里上学？", "en": "Where do they go to school?" },
  { "id": 31, "zh": "我总是准时到校。", "en": "I always arrive at school on time." },
  { "id": 32, "zh": "她通常吃早饭。", "en": "She usually eats breakfast." },
  { "id": 33, "zh": "他经常帮助同学。", "en": "He often helps his classmates." },
  { "id": 34, "zh": "我有时候忘记作业。", "en": "I sometimes forget my homework." },
  { "id": 35, "zh": "他从不说谎。", "en": "He never tells lies." },
  { "id": 36, "zh": "我们通常在六点吃晚饭。", "en": "We usually have dinner at six." },
  { "id": 37, "zh": "她总是很开心。", "en": "She is always happy." },
  { "id": 38, "zh": "他有时候迟到。", "en": "He is sometimes late." },
  { "id": 39, "zh": "我从不吃快餐。", "en": "I never eat fast food." },
  { "id": 40, "zh": "你经常锻炼吗？", "en": "Do you often exercise?" },
  { "id": 41, "zh": "他总是做完作业再玩。", "en": "He always finishes homework before playing." },
  { "id": 42, "zh": "我们有时候一起去图书馆。", "en": "We sometimes go to the library together." },
  { "id": 43, "zh": "她从不看恐怖电影。", "en": "She never watches horror movies." },
  { "id": 44, "zh": "他通常骑自行车上学。", "en": "He usually rides his bike to school." },
  { "id": 45, "zh": "你们总是这么早来吗？", "en": "Do you always come this early?" },
  { "id": 46, "zh": "太阳从东方升起。", "en": "The sun rises in the east." },
  { "id": 47, "zh": "水在100度沸腾。", "en": "Water boils at 100 degrees." },
  { "id": 48, "zh": "地球绕太阳转。", "en": "The earth goes around the sun." },
  { "id": 49, "zh": "鱼在水里生活。", "en": "Fish live in water." },
  { "id": 50, "zh": "植物需要阳光和水。", "en": "Plants need sunlight and water." },
  { "id": 51, "zh": "熊在冬天冬眠。", "en": "Bears sleep in winter." },
  { "id": 52, "zh": "蜜蜂采集花蜜。", "en": "Bees collect nectar." },
  { "id": 53, "zh": "光的速度比声音快。", "en": "Light travels faster than sound." },
  { "id": 54, "zh": "春天之后是夏天。", "en": "Summer comes after spring." },
  { "id": 55, "zh": "月亮绕地球转。", "en": "The moon goes around the earth." },
  { "id": 56, "zh": "鸟用翅膀飞翔。", "en": "Birds fly with their wings." },
  { "id": 57, "zh": "冰在零度以下结冰。", "en": "Water freezes below zero degrees." },
  { "id": 58, "zh": "树叶在秋天变黄。", "en": "Leaves turn yellow in autumn." },
  { "id": 59, "zh": "人类需要空气才能生存。", "en": "Humans need air to survive." },
  { "id": 60, "zh": "中国有很多人口。", "en": "China has a large population." }
